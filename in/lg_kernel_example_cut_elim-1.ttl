@prefix cat:  <https://example.org/cat#> .
@prefix lg:   <https://example.org/lg#> .
@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

lg:W a lg:WorldCategory .

lg:W0 a lg:WorldState ;
  cat:inCategory lg:W .

lg:W1 a lg:WorldState ;
  cat:inCategory lg:W .

lg:eatTransition
  a lg:ExecutableTransition ;
  cat:dom lg:W0 ;
  cat:cod lg:W1 ;
  cat:inCategory lg:W .

lg:G0 a lg:GrammarState .
lg:G1 a lg:GrammarState .

lg:eatIdentifier a lg:Identifier .

lg:eatSyntaxClause a lg:SyntacticRule .
lg:eatTypingClause a lg:TypingRule ;
  lg:fiberOverSyntaxClause lg:eatSyntaxClause .
lg:eatCategoricalClause a lg:CategoricalRule ;
  lg:indexedByTypingClause lg:eatTypingClause ;
  lg:denotesTransition lg:eatTransition .

lg:EatRule
  a lg:AugmentedRule ;
  lg:hasSyntaxClause lg:eatSyntaxClause ;
  lg:hasTypingClause lg:eatTypingClause ;
  lg:hasCategoricalClause lg:eatCategoricalClause ;
  lg:introducesIdentifier lg:eatIdentifier .

lg:G0 lg:hasRule lg:EatRule .
lg:G1 lg:hasRule lg:EatRule ;
      lg:hasEmergentIdentifier lg:eatIdentifier .

lg:eatEvolution
  a lg:EvolutionStep ;
  lg:fromGrammarState lg:G0 ;
  lg:viaRule lg:EatRule ;
  lg:toGrammarState lg:G1 ;
  cat:dom lg:G0 ;
  cat:cod lg:G1 .

lg:eatTerm a lg:CoreTerm ;
  lg:reifiesAsHandle lg:eatHandle .

lg:eatHandle a lg:Handle ;
  lg:reflectsHandle lg:eatTerm .

lg:eatVerbType a lg:SemanticType .

lg:eatTypingJudgment
  a lg:TypingJudgment ;
  lg:judgesTerm lg:eatTerm ;
  lg:judgesType lg:eatVerbType ;
  lg:judgesInWorldState lg:W0 ;
  lg:judgesUnderGrammarState lg:G0 .

lg:thisVar a lg:ReservedVariable ;
  lg:variableName "this" .

lg:demoRuleVar a lg:QueryVariable ;
  lg:variableName "r" .

lg:demoGrammarVar a lg:QueryVariable ;
  lg:variableName "g2" .

lg:demoRulePersistenceQuery
  a lg:SelectQuery ;
  lg:projectsVariable lg:thisVar ;
  lg:wherePattern [
    a lg:AntiJoinPattern ;
    lg:leftPattern [
      a lg:JoinPattern ;
      lg:leftPattern [
        a lg:TriplePattern ;
        lg:subjectTerm lg:thisVar ;
        lg:predicateTerm lg:viaRule ;
        lg:objectTerm lg:demoRuleVar
      ] ;
      lg:rightPattern [
        a lg:TriplePattern ;
        lg:subjectTerm lg:thisVar ;
        lg:predicateTerm lg:toGrammarState ;
        lg:objectTerm lg:demoGrammarVar
      ]
    ] ;
    lg:rightPattern [
      a lg:TriplePattern ;
      lg:subjectTerm lg:demoGrammarVar ;
      lg:predicateTerm lg:hasRule ;
      lg:objectTerm lg:demoRuleVar
    ]
  ] .

lg:demoRulePersistenceRendering
  a lg:QueryRendering ;
  lg:wrapsQueryAST lg:demoRulePersistenceQuery ;
  rdf:value """
    SELECT $this
    WHERE {
      $this lg:viaRule ?r ;
            lg:toGrammarState ?g2 .
      FILTER NOT EXISTS { ?g2 lg:hasRule ?r . }
    }
  """ .

lg:demoRulePersistenceConstraint
  a lg:SPARQLConstraint ;
  lg:hasQueryAST lg:demoRulePersistenceQuery ;
  lg:hasQueryRendering lg:demoRulePersistenceRendering ;
  sh:select """
    SELECT $this
    WHERE {
      $this lg:viaRule ?r ;
            lg:toGrammarState ?g2 .
      FILTER NOT EXISTS { ?g2 lg:hasRule ?r . }
    }
  """ .


# ---- Galois / polarity example ----

lg:NatSemiring a lg:Semiring .
lg:BoolSemiring a lg:Semiring .

lg:natSupportReflection
  a lg:SupportReflection ;
  cat:dom lg:NatSemiring ;
  cat:cod lg:BoolSemiring .

lg:eatWitnessDomain a lg:WitnessDomain .
lg:eatPredicateDomain a lg:PredicateDomain .

lg:eatIncidence
  a lg:IncidenceRelation ;
  cat:dom lg:eatWitnessDomain ;
  cat:cod lg:eatPredicateDomain .

lg:eatWitnessDerivation
  a lg:DerivationOperator ;
  cat:dom lg:eatWitnessDomain ;
  cat:cod lg:eatPredicateDomain .

lg:eatPredicateDerivation
  a lg:DerivationOperator ;
  cat:dom lg:eatPredicateDomain ;
  cat:cod lg:eatWitnessDomain .

lg:eatExtentClosure
  a lg:ClosureOperator ;
  cat:dom lg:eatWitnessDomain ;
  cat:cod lg:eatWitnessDomain .

lg:eatIntentClosure
  a lg:ClosureOperator ;
  cat:dom lg:eatPredicateDomain ;
  cat:cod lg:eatPredicateDomain .

lg:eatRulePolarity
  a lg:RulePolarity ;
  lg:hasWitnessDomain lg:eatWitnessDomain ;
  lg:hasPredicateDomain lg:eatPredicateDomain ;
  lg:hasIncidenceRelation lg:eatIncidence ;
  lg:valuedInSemiring lg:NatSemiring ;
  lg:hasSupportReflection lg:natSupportReflection ;
  lg:hasWitnessDerivation lg:eatWitnessDerivation ;
  lg:hasPredicateDerivation lg:eatPredicateDerivation ;
  lg:hasExtentClosure lg:eatExtentClosure ;
  lg:hasIntentClosure lg:eatIntentClosure .

lg:eatMatrixFace a lg:MatrixPresentation .
lg:eatKleisliFace a lg:KleisliPresentation .
lg:eatPredicateFace a lg:PredicatePresentation .

lg:eatSemanticAtlas
  a lg:SemanticAtlas ;
  lg:hasMatrixPresentation lg:eatMatrixFace ;
  lg:hasKleisliPresentation lg:eatKleisliFace ;
  lg:hasPredicatePresentation lg:eatPredicateFace .

lg:eatCategoricalClause lg:hasSemanticAtlas lg:eatSemanticAtlas .

lg:eatClosedExtent a lg:ClosedExtent .
lg:eatClosedIntent a lg:ClosedIntent .

lg:EatRule a lg:ClosedRuleCell ;
  lg:hasPolarity lg:eatRulePolarity ;
  lg:hasClosedExtent lg:eatClosedExtent ;
  lg:hasClosedIntent lg:eatClosedIntent .


# ---- Quotient recovery and concept lattice example ----

lg:eatSyntaxKernel a lg:KernelCongruence .
lg:eatTypingKernel a lg:KernelCongruence .
lg:eatSemanticKernel a lg:KernelCongruence .
lg:eatExtentKernel a lg:KernelCongruence .
lg:eatIntentKernel a lg:KernelCongruence .

lg:eatSyntaxProjection
  a lg:QuotientProjection ;
  cat:dom lg:EatRule ;
  cat:cod lg:eatSyntaxClause ;
  lg:quotientsBy lg:eatSyntaxKernel .

lg:eatTypingProjection
  a lg:QuotientProjection ;
  cat:dom lg:EatRule ;
  cat:cod lg:eatTypingClause ;
  lg:quotientsBy lg:eatTypingKernel .

lg:eatSemanticProjection
  a lg:QuotientProjection ;
  cat:dom lg:EatRule ;
  cat:cod lg:eatCategoricalClause ;
  lg:quotientsBy lg:eatSemanticKernel .

lg:eatExtentProjection
  a lg:QuotientProjection ;
  cat:dom lg:EatRule ;
  cat:cod lg:eatClosedExtent ;
  lg:quotientsBy lg:eatExtentKernel .

lg:eatIntentProjection
  a lg:QuotientProjection ;
  cat:dom lg:EatRule ;
  cat:cod lg:eatClosedIntent ;
  lg:quotientsBy lg:eatIntentKernel .

lg:eatConceptOrder a lg:OrderRelation .
lg:eatConceptMeet a lg:MeetOperation .
lg:eatConceptJoin a lg:JoinOperation .

lg:eatTopExtent a lg:ClosedExtent .
lg:eatTopIntent a lg:ClosedIntent .
lg:eatBottomExtent a lg:ClosedExtent .
lg:eatBottomIntent a lg:ClosedIntent .

lg:eatFormalConcept
  a lg:FormalConcept ;
  lg:formalExtent lg:eatClosedExtent ;
  lg:formalIntent lg:eatClosedIntent .

lg:eatTopConcept
  a lg:FormalConcept ;
  lg:formalExtent lg:eatTopExtent ;
  lg:formalIntent lg:eatTopIntent .

lg:eatBottomConcept
  a lg:FormalConcept ;
  lg:formalExtent lg:eatBottomExtent ;
  lg:formalIntent lg:eatBottomIntent .

lg:eatConceptLattice
  a lg:ConceptLattice ;
  lg:generatedByPolarity lg:eatRulePolarity ;
  lg:hasFormalConcept lg:eatFormalConcept, lg:eatTopConcept, lg:eatBottomConcept ;
  lg:hasTopConcept lg:eatTopConcept ;
  lg:hasBottomConcept lg:eatBottomConcept ;
  lg:hasOrderRelation lg:eatConceptOrder ;
  lg:hasMeetOperation lg:eatConceptMeet ;
  lg:hasJoinOperation lg:eatConceptJoin .

lg:eatRulePolarity lg:inducesConceptLattice lg:eatConceptLattice .

lg:eatFormalConcept lg:memberOfLattice lg:eatConceptLattice .
lg:eatTopConcept lg:memberOfLattice lg:eatConceptLattice .
lg:eatBottomConcept lg:memberOfLattice lg:eatConceptLattice .

lg:EatRule
  lg:hasSyntaxProjection lg:eatSyntaxProjection ;
  lg:hasTypingProjection lg:eatTypingProjection ;
  lg:hasSemanticProjection lg:eatSemanticProjection ;
  lg:hasExtentProjection lg:eatExtentProjection ;
  lg:hasIntentProjection lg:eatIntentProjection ;
  lg:realizesFormalConcept lg:eatFormalConcept .


# ---- Theorem / proof-obligation example ----

lg:meetAssocSchema a lg:LawSchema .
lg:joinAssocSchema a lg:LawSchema .
lg:meetCommSchema a lg:LawSchema .
lg:joinCommSchema a lg:LawSchema .
lg:meetIdemSchema a lg:LawSchema .
lg:joinIdemSchema a lg:LawSchema .
lg:absorptionSchema a lg:LawSchema .
lg:boundednessSchema a lg:LawSchema .
lg:orderCompatibilitySchema a lg:LawSchema .

lg:eatMeetAssociativityObligation
  a lg:MeetAssociativityObligation ;
  lg:statesLawSchema lg:meetAssocSchema ;
  lg:governsLattice lg:eatConceptLattice ;
  lg:governsMeetOperation lg:eatConceptMeet .

lg:eatJoinAssociativityObligation
  a lg:JoinAssociativityObligation ;
  lg:statesLawSchema lg:joinAssocSchema ;
  lg:governsLattice lg:eatConceptLattice ;
  lg:governsJoinOperation lg:eatConceptJoin .

lg:eatMeetCommutativityObligation
  a lg:MeetCommutativityObligation ;
  lg:statesLawSchema lg:meetCommSchema ;
  lg:governsLattice lg:eatConceptLattice ;
  lg:governsMeetOperation lg:eatConceptMeet .

lg:eatJoinCommutativityObligation
  a lg:JoinCommutativityObligation ;
  lg:statesLawSchema lg:joinCommSchema ;
  lg:governsLattice lg:eatConceptLattice ;
  lg:governsJoinOperation lg:eatConceptJoin .

lg:eatMeetIdempotenceObligation
  a lg:MeetIdempotenceObligation ;
  lg:statesLawSchema lg:meetIdemSchema ;
  lg:governsLattice lg:eatConceptLattice ;
  lg:governsMeetOperation lg:eatConceptMeet .

lg:eatJoinIdempotenceObligation
  a lg:JoinIdempotenceObligation ;
  lg:statesLawSchema lg:joinIdemSchema ;
  lg:governsLattice lg:eatConceptLattice ;
  lg:governsJoinOperation lg:eatConceptJoin .

lg:eatAbsorptionObligation
  a lg:AbsorptionObligation ;
  lg:statesLawSchema lg:absorptionSchema ;
  lg:governsLattice lg:eatConceptLattice ;
  lg:governsMeetOperation lg:eatConceptMeet ;
  lg:governsJoinOperation lg:eatConceptJoin .

lg:eatBoundednessObligation
  a lg:BoundednessObligation ;
  lg:statesLawSchema lg:boundednessSchema ;
  lg:governsLattice lg:eatConceptLattice ;
  lg:governsTopConcept lg:eatTopConcept ;
  lg:governsBottomConcept lg:eatBottomConcept .

lg:eatOrderCompatibilityObligation
  a lg:OrderCompatibilityObligation ;
  lg:statesLawSchema lg:orderCompatibilitySchema ;
  lg:governsLattice lg:eatConceptLattice ;
  lg:governsOrderRelation lg:eatConceptOrder ;
  lg:governsMeetOperation lg:eatConceptMeet ;
  lg:governsJoinOperation lg:eatConceptJoin .

lg:eatConceptLattice
  lg:hasMeetAssociativityObligation lg:eatMeetAssociativityObligation ;
  lg:hasJoinAssociativityObligation lg:eatJoinAssociativityObligation ;
  lg:hasMeetCommutativityObligation lg:eatMeetCommutativityObligation ;
  lg:hasJoinCommutativityObligation lg:eatJoinCommutativityObligation ;
  lg:hasMeetIdempotenceObligation lg:eatMeetIdempotenceObligation ;
  lg:hasJoinIdempotenceObligation lg:eatJoinIdempotenceObligation ;
  lg:hasAbsorptionObligation lg:eatAbsorptionObligation ;
  lg:hasBoundednessObligation lg:eatBoundednessObligation ;
  lg:hasOrderCompatibilityObligation lg:eatOrderCompatibilityObligation .

lg:eatMeetAssocWitness a lg:ProofWitness ;
  lg:witnessesObligation lg:eatMeetAssociativityObligation .
lg:eatJoinAssocWitness a lg:ProofWitness ;
  lg:witnessesObligation lg:eatJoinAssociativityObligation .
lg:eatAbsorptionWitness a lg:ProofWitness ;
  lg:witnessesObligation lg:eatAbsorptionObligation .

lg:eatMeetAssociativityObligation lg:hasProofWitness lg:eatMeetAssocWitness .
lg:eatJoinAssociativityObligation lg:hasProofWitness lg:eatJoinAssocWitness .
lg:eatAbsorptionObligation lg:hasProofWitness lg:eatAbsorptionWitness .

lg:quotientUniversalitySchema a lg:UniversalPropertySchema .

lg:eatSyntaxFactorizationSchema a lg:FactorizationSchema .
lg:eatSyntaxUniquenessSchema a lg:UniquenessSchema .
lg:eatTypingFactorizationSchema a lg:FactorizationSchema .
lg:eatTypingUniquenessSchema a lg:UniquenessSchema .
lg:eatSemanticFactorizationSchema a lg:FactorizationSchema .
lg:eatSemanticUniquenessSchema a lg:UniquenessSchema .
lg:eatExtentFactorizationSchema a lg:FactorizationSchema .
lg:eatExtentUniquenessSchema a lg:UniquenessSchema .
lg:eatIntentFactorizationSchema a lg:FactorizationSchema .
lg:eatIntentUniquenessSchema a lg:UniquenessSchema .

lg:eatSyntaxUniversalityObligation
  a lg:QuotientUniversalityObligation ;
  lg:statesLawSchema lg:quotientUniversalitySchema ;
  lg:governsProjection lg:eatSyntaxProjection ;
  lg:governsKernelCongruence lg:eatSyntaxKernel ;
  lg:governsQuotientFace lg:eatSyntaxClause ;
  lg:hasFactorizationSchema lg:eatSyntaxFactorizationSchema ;
  lg:hasUniquenessSchema lg:eatSyntaxUniquenessSchema .

lg:eatTypingUniversalityObligation
  a lg:QuotientUniversalityObligation ;
  lg:statesLawSchema lg:quotientUniversalitySchema ;
  lg:governsProjection lg:eatTypingProjection ;
  lg:governsKernelCongruence lg:eatTypingKernel ;
  lg:governsQuotientFace lg:eatTypingClause ;
  lg:hasFactorizationSchema lg:eatTypingFactorizationSchema ;
  lg:hasUniquenessSchema lg:eatTypingUniquenessSchema .

lg:eatSemanticUniversalityObligation
  a lg:QuotientUniversalityObligation ;
  lg:statesLawSchema lg:quotientUniversalitySchema ;
  lg:governsProjection lg:eatSemanticProjection ;
  lg:governsKernelCongruence lg:eatSemanticKernel ;
  lg:governsQuotientFace lg:eatCategoricalClause ;
  lg:hasFactorizationSchema lg:eatSemanticFactorizationSchema ;
  lg:hasUniquenessSchema lg:eatSemanticUniquenessSchema .

lg:eatExtentUniversalityObligation
  a lg:QuotientUniversalityObligation ;
  lg:statesLawSchema lg:quotientUniversalitySchema ;
  lg:governsProjection lg:eatExtentProjection ;
  lg:governsKernelCongruence lg:eatExtentKernel ;
  lg:governsQuotientFace lg:eatClosedExtent ;
  lg:hasFactorizationSchema lg:eatExtentFactorizationSchema ;
  lg:hasUniquenessSchema lg:eatExtentUniquenessSchema .

lg:eatIntentUniversalityObligation
  a lg:QuotientUniversalityObligation ;
  lg:statesLawSchema lg:quotientUniversalitySchema ;
  lg:governsProjection lg:eatIntentProjection ;
  lg:governsKernelCongruence lg:eatIntentKernel ;
  lg:governsQuotientFace lg:eatClosedIntent ;
  lg:hasFactorizationSchema lg:eatIntentFactorizationSchema ;
  lg:hasUniquenessSchema lg:eatIntentUniquenessSchema .

lg:eatSyntaxProjection lg:hasQuotientUniversalityObligation lg:eatSyntaxUniversalityObligation .
lg:eatTypingProjection lg:hasQuotientUniversalityObligation lg:eatTypingUniversalityObligation .
lg:eatSemanticProjection lg:hasQuotientUniversalityObligation lg:eatSemanticUniversalityObligation .
lg:eatExtentProjection lg:hasQuotientUniversalityObligation lg:eatExtentUniversalityObligation .
lg:eatIntentProjection lg:hasQuotientUniversalityObligation lg:eatIntentUniversalityObligation .



# ---- Reflective SHACL boundary example ----

lg:coreConstraintProofCalculus
  a lg:InternalProofCalculus .

lg:coreConstraintDenotationCategory
  a lg:SHACLDenotationCategory .

lg:coreSupportedSHACLFragment
  a lg:WellFormedSHACLFragment .

lg:coreObservationalEquivalence
  a lg:ObservationalEquivalence .

lg:demoRulePersistenceDenotation
  a lg:ConstraintDenotation ;
  cat:inCategory lg:coreConstraintDenotationCategory ;
  lg:representedByConstraintArtifact lg:demoRulePersistenceConstraint ;
  lg:canonicalInternalRepresentative lg:demoRulePersistenceProofTerm .

lg:demoRulePersistenceProofTerm
  a lg:InternalProofTerm ;
  cat:inCategory lg:coreConstraintProofCalculus ;
  lg:denotesConstraint lg:demoRulePersistenceDenotation .

lg:demoRulePersistenceDerivation
  a lg:InternalDerivation ;
  cat:inCategory lg:coreConstraintProofCalculus ;
  lg:derivesInternalProofTerm lg:demoRulePersistenceProofTerm .

lg:coreConstraintProofCalculus
  lg:hasInternalProofTerm lg:demoRulePersistenceProofTerm ;
  lg:hasInternalDerivation lg:demoRulePersistenceDerivation .

lg:coreConstraintQuotient
  a lg:DenotationalQuotient ;
  lg:quotientsFragment lg:coreSupportedSHACLFragment ;
  lg:byConstraintEquivalence lg:coreObservationalEquivalence ;
  lg:hasDenotationCategory lg:coreConstraintDenotationCategory ;
  lg:hasConstraintDenotation lg:demoRulePersistenceDenotation .

lg:coreLoweringFunctor
  a lg:LoweringFunctor ;
  cat:sourceCategory lg:coreConstraintProofCalculus ;
  cat:targetCategory lg:coreConstraintDenotationCategory .

lg:coreReflectionFunctor
  a lg:ReflectionFunctor ;
  cat:sourceCategory lg:coreConstraintDenotationCategory ;
  cat:targetCategory lg:coreConstraintProofCalculus .

lg:coreLoweringSoundnessWitness a lg:ProofWitness .
lg:coreSHACLSurjectivityWitness a lg:ProofWitness .
lg:coreReflectiveQuotientWitness a lg:ProofWitness .
lg:coreConservativeProjectionWitness a lg:ProofWitness .

lg:coreReflectiveBoundary
  a lg:ReflectiveSHACLBoundary ;
  lg:hasInternalProofCalculus lg:coreConstraintProofCalculus ;
  lg:supportsSHACLFragment lg:coreSupportedSHACLFragment ;
  lg:hasConstraintEquivalence lg:coreObservationalEquivalence ;
  lg:hasDenotationalQuotient lg:coreConstraintQuotient ;
  lg:hasLoweringFunctor lg:coreLoweringFunctor ;
  lg:hasReflectionFunctor lg:coreReflectionFunctor ;
  lg:hasLoweringSoundnessObligation lg:coreLoweringSoundnessObligation ;
  lg:hasSHACLSurjectivityObligation lg:coreSHACLSurjectivityObligation ;
  lg:hasReflectiveQuotientObligation lg:coreReflectiveQuotientObligation ;
  lg:hasConservativeProjectionObligation lg:coreConservativeProjectionObligation .

lg:coreLoweringSoundnessObligation
  a lg:LoweringSoundnessObligation ;
  lg:governsBoundary lg:coreReflectiveBoundary ;
  lg:governsProofCalculus lg:coreConstraintProofCalculus ;
  lg:governsSHACLFragment lg:coreSupportedSHACLFragment ;
  lg:governsConstraintEquivalence lg:coreObservationalEquivalence ;
  lg:governsDenotationalQuotient lg:coreConstraintQuotient ;
  lg:governsLoweringFunctor lg:coreLoweringFunctor ;
  lg:hasProofWitness lg:coreLoweringSoundnessWitness .

lg:coreSHACLSurjectivityObligation
  a lg:SHACLSurjectivityObligation ;
  lg:governsBoundary lg:coreReflectiveBoundary ;
  lg:governsProofCalculus lg:coreConstraintProofCalculus ;
  lg:governsSHACLFragment lg:coreSupportedSHACLFragment ;
  lg:governsConstraintEquivalence lg:coreObservationalEquivalence ;
  lg:governsDenotationalQuotient lg:coreConstraintQuotient ;
  lg:governsLoweringFunctor lg:coreLoweringFunctor ;
  lg:hasProofWitness lg:coreSHACLSurjectivityWitness .

lg:coreReflectiveQuotientObligation
  a lg:ReflectiveQuotientObligation ;
  lg:governsBoundary lg:coreReflectiveBoundary ;
  lg:governsProofCalculus lg:coreConstraintProofCalculus ;
  lg:governsSHACLFragment lg:coreSupportedSHACLFragment ;
  lg:governsConstraintEquivalence lg:coreObservationalEquivalence ;
  lg:governsDenotationalQuotient lg:coreConstraintQuotient ;
  lg:governsLoweringFunctor lg:coreLoweringFunctor ;
  lg:governsReflectionFunctor lg:coreReflectionFunctor ;
  lg:hasProofWitness lg:coreReflectiveQuotientWitness .

lg:coreConservativeProjectionObligation
  a lg:ConservativeProjectionObligation ;
  lg:governsBoundary lg:coreReflectiveBoundary ;
  lg:governsProofCalculus lg:coreConstraintProofCalculus ;
  lg:governsSHACLFragment lg:coreSupportedSHACLFragment ;
  lg:governsConstraintEquivalence lg:coreObservationalEquivalence ;
  lg:governsDenotationalQuotient lg:coreConstraintQuotient ;
  lg:governsLoweringFunctor lg:coreLoweringFunctor ;
  lg:hasProofWitness lg:coreConservativeProjectionWitness .


# ---- Proof-carrying query / immutable history example ----

lg:historyLineage0 a lg:HistoryLineage .

lg:historyState0
  a lg:HistoryState ;
  lg:stateDigest "sha256:history-state-0" ;
  lg:hasHistoricalAssertion lg:histAssertViaRule ;
  lg:hasHistoricalAssertion lg:histAssertToGrammar ;
  lg:hasHistoricalAssertion lg:histAssertHasRule ;
  lg:hasHistoricalAssertion lg:histAssertHasIdentifier .

lg:historyLineage0
  lg:hasHistoryState lg:historyState0 ;
  lg:hasHistoryImmutabilityObligation lg:historyLineage0ImmutabilityObligation .

lg:historyLineage0ImmutabilityObligation
  a lg:HistoryImmutabilityObligation ;
  lg:governsHistoryLineage lg:historyLineage0 ;
  lg:hasProofWitness lg:historyLineage0ImmutabilityWitness .

lg:historyLineage0ImmutabilityWitness a lg:ProofWitness .

lg:histAssertViaRule
  a lg:HistoricalAssertion ;
  lg:assertionSubject lg:eatEvolution ;
  lg:assertionPredicate lg:viaRule ;
  lg:assertionObject lg:EatRule .

lg:histAssertToGrammar
  a lg:HistoricalAssertion ;
  lg:assertionSubject lg:eatEvolution ;
  lg:assertionPredicate lg:toGrammarState ;
  lg:assertionObject lg:G1 .

lg:histAssertHasRule
  a lg:HistoricalAssertion ;
  lg:assertionSubject lg:G1 ;
  lg:assertionPredicate lg:hasRule ;
  lg:assertionObject lg:EatRule .

lg:histAssertHasIdentifier
  a lg:HistoricalAssertion ;
  lg:assertionSubject lg:G1 ;
  lg:assertionPredicate lg:hasEmergentIdentifier ;
  lg:assertionObject lg:eatIdentifier .

lg:evolutionLookupVar a lg:QueryVariable ;
  lg:variableName "r" .

lg:evolutionLookupQuery
  a lg:SelectQuery ;
  lg:projectsVariable lg:thisVar ;
  lg:wherePattern [
    a lg:TriplePattern ;
    lg:subjectTerm lg:thisVar ;
    lg:predicateTerm lg:viaRule ;
    lg:objectTerm lg:evolutionLookupVar
  ] .

lg:evolutionLookupRendering
  a lg:QueryRendering ;
  lg:wrapsQueryAST lg:evolutionLookupQuery ;
  rdf:value """
    SELECT $this
    WHERE {
      $this lg:viaRule ?r .
    }
  """ .

lg:evolutionLookupAlgebra
  a lg:ProjectAlgebraExpression .

lg:evolutionLookupConstraint
  a lg:SPARQLConstraint ;
  lg:hasQueryAST lg:evolutionLookupQuery ;
  lg:hasQueryRendering lg:evolutionLookupRendering ;
  sh:select """
    SELECT $this
    WHERE {
      $this lg:viaRule ?r .
    }
  """ .

lg:evolutionLookupDenotation
  a lg:ConstraintDenotation ;
  cat:inCategory lg:coreConstraintDenotationCategory ;
  lg:representedByConstraintArtifact lg:evolutionLookupConstraint ;
  lg:canonicalInternalRepresentative lg:evolutionLookupProofQuery .

